{% extends "_layouts/base" %}

{% set org = entry %}
{% set orgImage = org.featuredImage.one() %}

{% block content %}

<div class="scv-article-wrap">

  <main>
    <article class="scv-entry">

      <nav class="scv-breadcrumb">
        <a href="{{ siteUrl }}">Home</a>
        <span class="scv-bc-sep">›</span>
        <a href="{{ siteUrl }}organizations">Organizations</a>
        <span class="scv-bc-sep">›</span>
        <span>{{ org.title }}</span>
      </nav>

      <header class="scv-entry-header">
        {% if orgImage %}
          <div class="scv-entry-header__image">
            <img src="{{ orgImage.url }}" alt="{{ org.title }}">
          </div>
        {% endif %}

        <div class="scv-entry-header__text">
          <h1 class="scv-entry-title">{{ org.title }}</h1>

          {% if org.orgAliases %}
            <p class="scv-entry-aliases">Also known as {{ org.orgAliases }}</p>
          {% endif %}

          <div class="scv-entry-meta">
  {% if org.dateFounded %}
    <p><strong>Founded:</strong> {{ org.dateFounded }}</p>
  {% endif %}
</div>
          {% set eras = org.historicalEra.all() %}
          {% if eras|length %}
            <div class="scv-tags">
              {% for era in eras %}
                <span class="scv-tag scv-tag--era">{{ era.title }}</span>
              {% endfor %}
            </div>
          {% endif %}
        </div>
      </header>

      <hr class="scv-header-rule">

      {% if org.body %}
        <div class="scv-entry-body">
          {{ org.body }}
        </div>
      {% endif %}

      {% if org.termNotes %}
        <div class="scv-entry-body">
          {{ org.termNotes }}
        </div>
      {% endif %}

      {% if org.orgFinePrint %}
        <div class="scv-entry-fineprint">
          {{ org.orgFinePrint }}
        </div>
      {% endif %}

    </article>
  </main>

  {# ── SIDEBAR ─────────────────────────────────────────────── #}
  <aside class="scv-sidebar">

    {# Founded By #}
    {% set founders = org.orgFoundedBy.all() %}
    {% if founders|length %}
      <div class="scv-sidebar-card">
        <h3 class="scv-sidebar-card-title">Founded By</h3>
        <div class="scv-sidebar-card-body">
          {% for person in founders %}
            {% set pImg = person.featuredImage.one() %}
            <a href="{{ person.url }}" class="scv-related-person">
              {% if pImg %}
                <img src="{{ pImg.getUrl('cardThumb') }}" alt="{{ person.title }}" class="scv-related-person__photo">
              {% else %}
                <div class="scv-related-person__photo scv-related-person__photo--placeholder"></div>
              {% endif %}
              <div class="scv-related-person__name">{{ person.title }}</div>
            </a>
          {% endfor %}
        </div>
      </div>
    {% endif %}

    {# Associated Persons #}
    {% set associated = org.orgAssociatedPersons.all() %}
    {% if associated|length %}
      <div class="scv-sidebar-card">
        <h3 class="scv-sidebar-card-title">Associated People</h3>
        <div class="scv-sidebar-card-body">
          {% for person in associated %}
            {% set pImg = person.featuredImage.one() %}
            <a href="{{ person.url }}" class="scv-related-person">
              {% if pImg %}
                <img src="{{ pImg.getUrl('cardThumb') }}" alt="{{ person.title }}" class="scv-related-person__photo">
              {% else %}
                <div class="scv-related-person__photo scv-related-person__photo--placeholder"></div>
              {% endif %}
              <div class="scv-related-person__name">{{ person.title }}</div>
            </a>
          {% endfor %}
        </div>
      </div>
    {% endif %}

    {# Parent Organization #}
    {% if org.hasParentOrg and org.parentOrganization.one() %}
      {% set parent = org.parentOrganization.one() %}
      <div class="scv-sidebar-card">
        <h3 class="scv-sidebar-card-title">Parent Organization</h3>
        <div class="scv-sidebar-card-body">
          <a href="{{ parent.url }}" class="scv-sidebar-link">{{ parent.title }}</a>
        </div>
      </div>
    {% endif %}

    {# External Links #}
    {% if org.orgWebsite or org.orgWikipediaUrl or org.orgLegacyUrl %}
      <div class="scv-sidebar-card">
        <h3 class="scv-sidebar-card-title">External Links</h3>
        <div class="scv-sidebar-card-body scv-external-links">
          {% if org.orgWebsite.value is defined and org.orgWebsite.value %}
  <a href="{{ org.orgWebsite.value }}" target="_blank" rel="noopener" class="scv-external-link">Official Website ↗</a>
{% endif %}
{% if org.orgWikipediaUrl.value is defined and org.orgWikipediaUrl.value %}
  <a href="{{ org.orgWikipediaUrl.value }}" target="_blank" rel="noopener" class="scv-external-link">Wikipedia ↗</a>
{% endif %}
          {% if org.orgLegacyUrl %}
            <a href="https://scvhistory.com/{{ org.orgLegacyUrl }}" target="_blank" rel="noopener" class="scv-external-link">View on Legacy Site ↗</a>
          {% endif %}
        </div>
      </div>
    {% endif %}
{# Location Map #}
{% if org.orgLat and org.orgLng %}
  <div class="scv-sidebar-card">
    <h3 class="scv-sidebar-card-title">Location</h3>
    <div class="scv-sidebar-card-body scv-sidebar-card-body--flush">
      <div id="org-map" class="scv-map" style="height:220px;"></div>
      <dl class="scv-location-meta">
        {% if org.orgAddress %}
          <dt>Address</dt>
          <dd>{{ org.orgAddress }}</dd>
        {% endif %}
        {% if org.orgLat and org.orgLng %}
          <dt>Lat</dt><dd>{{ org.orgLat }}</dd>
          <dt>Long</dt><dd>{{ org.orgLng }}</dd>
        {% endif %}
        {% if org.orgWebsite.value is defined and org.orgWebsite.value %}
          <dt>Website</dt>
          <dd><a href="{{ org.orgWebsite.value }}" target="_blank" rel="noopener">{{ org.orgWebsite.value|replace({'https://': '', 'http://': ''}) }}</a></dd>
        {% endif %}
      </dl>
    </div>
  </div>

  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.css">
  <script src="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.js"></script>
  <script>
    document.addEventListener('DOMContentLoaded', function() {
      var map = L.map('org-map', { zoomControl: true, scrollWheelZoom: false })
        .setView([{{ org.orgLat }}, {{ org.orgLng }}], 15);
      L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
        attribution: '© <a href="https://openstreetmap.org">OpenStreetMap</a>',
        maxZoom: 19
      }).addTo(map);
      L.marker([{{ org.orgLat }}, {{ org.orgLng }}])
        .addTo(map)
        .bindPopup('<strong>{{ org.title }}</strong>{% if org.orgAddress %}<br>{{ org.orgAddress }}{% endif %}');
    });
  </script>
{% endif %}

    {# Search #}
    <div class="scv-sidebar-card">
      <div class="scv-sidebar-card-body">
        {% include '_partials/search-form' only %}
      </div>
    </div>

    {# Cite This #}
    {% include '_partials/cite-article' with { entry: org } only %}

  </aside>

</div>{# .scv-article-wrap #}

{% endblock %}
