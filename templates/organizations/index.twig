{% extends "_layouts/base" %}

{% block content %}

{% set orgs = craft.entries()
  .section('organizations')
  .orderBy('title ASC')
  .all() %}

<div class="scv-article-wrap">

  <main>
    <article class="scv-index">

      <nav class="scv-breadcrumb">
        <a href="{{ siteUrl }}">Home</a>
        <span class="scv-bc-sep">›</span>
        <span>Organizations</span>
      </nav>

      <header class="scv-index-header">
        <h1>Organizations</h1>
        <p class="scv-index-count">{{ orgs|length }} organization{{ orgs|length != 1 ? 's' : '' }}</p>
      </header>

      <hr class="scv-header-rule">

      {% if orgs|length %}
      <ul class="scv-index-list">
        {% for org in orgs %}
          {% set orgImage = org.featuredImage.one() %}
          <li class="scv-index-item">
            <a href="{{ org.url }}" class="scv-index-item__link">

              <div class="scv-index-item__photo-wrap">
                {% if orgImage %}
                  <img src="{{ orgImage.url }}" alt="{{ org.title }}" class="scv-index-item__photo">
                {% else %}
                  <div class="scv-index-item__placeholder">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="48" height="48"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
                  </div>
                {% endif %}
              </div>

              <div class="scv-index-item__meta">
                <div class="scv-index-item__name">{{ org.title }}</div>

                {% if org.dateFounded %}
                  <div class="scv-index-item__detail">Est. {{ org.dateFounded }}</div>
                {% endif %}

                {% set eras = org.historicalEra.all() %}
                {% if eras|length %}
                  <div class="scv-tags scv-tags--compact">
                    {% for era in eras %}
                      <span class="scv-tag scv-tag--story-era">{{ era.title }}</span>
                    {% endfor %}
                  </div>
                {% endif %}
              </div>

            </a>
          </li>
        {% endfor %}
      </ul>
      {% else %}
        <p>No organizations found.</p>
      {% endif %}

    </article>
  </main>

  <aside class="scv-sidebar">

    <div class="scv-sidebar-card">
      <div class="scv-sidebar-card-body">
        {% include '_partials/search-form' only %}
      </div>
    </div>

  </aside>

</div>{# .scv-article-wrap #}

{% endblock %}
