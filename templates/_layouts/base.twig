<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% block title %}{{ entry is defined ? entry.title ~ ' | ' : '' }}SCVHistory.com{% endblock %}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="{{ siteUrl }}assets/css/main.css">
  <link rel="stylesheet" href="{{ siteUrl }}assets/css/layout.css">
  {% block head %}{% endblock %}
</head>
<body>

  {# ── Header ─────────────────────────────────────────────────────── #}
  <header class="scv-site-header">
    <div class="scv-site-header__inner">
      <a href="{{ siteUrl }}" class="scv-site-header__logo">
        <img src="{{ siteUrl }}uploads/archive-media/site/scvhistory-logo-light.svg"
             alt="SCVHistory.com — Santa Clarita Valley History Archives"
             height="56">
      </a>
      <nav class="scv-site-nav">
        <a href="{{ url('persons') }}">People</a>
        <a href="{{ url('places') }}">Places</a>
        <a href="{{ url('organizations') }}">Organizations</a>
        <a href="{{ url('collections') }}">Collections</a>
        <a href="{{ url('articles') }}">Articles</a>
      </nav>
    </div>
  </header>

  {# ── Main Content ────────────────────────────────────────────────── #}
  <div id="content">
    {% block content %}{% endblock %}
  </div>

  {# ── Footer ──────────────────────────────────────────────────────── #}
  <footer class="scv-footer">
    <div class="scv-footer-inner">

      <div class="scv-footer-brand">
        <a href="{{ siteUrl }}" class="scv-footer-logo">
          <img src="{{ siteUrl }}uploads/archive-media/site/scvhistory-logo-light.svg"
               alt="SCVHistory.com" style="height:48px;width:auto;">
        </a>
        <p class="scv-footer-tagline">
          A free public archive of Santa Clarita Valley History.<br>
          A service of SCVTV, a 501(c)(3) nonprofit.
        </p>
      </div>

      <div class="scv-footer-col">
        <p class="scv-footer-heading">Browse</p>
        <a href="{{ url('articles') }}">By Era</a>
        <a href="{{ url('collections') }}">By Collection</a>
        <a href="{{ url('persons') }}">People</a>
        <a href="{{ url('obituaries') }}">Obituaries</a>
      </div>

      <div class="scv-footer-col">
        <p class="scv-footer-heading">About</p>
        <a href="{{ url('about') }}">About</a>
        <a href="{{ url('contact') }}">Contact</a>
        <a href="{{ url('permissions') }}">Permissions</a>
        <a href="{{ url('photo-credits') }}">Photo Credits</a>
        <a href="https://scvhs.org" target="_blank" rel="noopener">SCV Historical Society</a>
      </div>

      <div class="scv-footer-col">
        <p class="scv-footer-heading">Connect</p>
        <a href="https://www.facebook.com/groups/scvhistory" target="_blank" rel="noopener">Facebook Group</a>
        <a href="{{ url('newsletter') }}">Newsletter</a>
        <a href="{{ url('submit') }}">Submit a photo/article</a>
      </div>

    </div>

    <div class="scv-footer-bottom">
      <span>&copy; {{ now|date('Y') }} Santa Clarita Valley Historical Society</span>
      <span class="scv-footer-bottom-links">
        <a href="{{ url('nonprofit') }}">Nonprofit</a>
        &bull;
        <a href="{{ url('permissions') }}">Permissions</a>
        &bull;
        <a href="{{ url('privacy') }}">Privacy Policy</a>
      </span>
    </div>
  </footer>

  {# ── Lightbox ────────────────────────────────────────────────────── #}
  <div id="scv-lightbox" class="scv-lightbox" aria-modal="true" role="dialog">
    <button class="scv-lightbox__close" onclick="scvCloseLightbox()" aria-label="Close">&times;</button>
    <button class="scv-lightbox__prev" onclick="scvLightboxNav(-1)" aria-label="Previous">&#8592;</button>
    <button class="scv-lightbox__next" onclick="scvLightboxNav(1)" aria-label="Next">&#8594;</button>
    <div class="scv-lightbox__stage">
      <img id="scv-lb-img" src="" alt="">
      <div class="scv-lightbox__caption">
        <div id="scv-lb-caption"></div>
        <div id="scv-lb-counter"></div>
      </div>
    </div>
  </div>

  <script src="{{ siteUrl }}assets/js/main.js"></script>
  {% block foot %}{% endblock %}

</body>
</html>
