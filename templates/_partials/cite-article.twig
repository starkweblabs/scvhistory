{#
  _partials/cite-article.twig
  Usage: {% include '_partials/cite-article' with { entry: entry } only %}
#}

{% set authors = entry.writtenBy is defined ? entry.writtenBy.all() : [] %}
{% set authorStr = authors|map(a => a.title)|join(', ') %}
{% set publishedBy = entry.publishedBy is defined ? entry.publishedBy.one() : null %}
{% set publisher = publishedBy ? publishedBy.title : 'SCVHistory.com' %}
{% set pubDate = entry.originalPublishDate is defined ? entry.originalPublishDate : '' %}
{% set today = now|date('F j, Y') %}
{% set entryUrl = entry.url %}
{% set title = entry.title %}

{% set chicago = (authorStr ? authorStr ~ '. ' : '') ~ '"' ~ title ~ '." ' ~ publisher ~ (pubDate ? ', ' ~ pubDate : '') ~ '. Accessed ' ~ today ~ '. ' ~ entryUrl ~ '.' %}
{% set mla = (authorStr ? authorStr ~ '. ' : '') ~ '"' ~ title ~ '." ' ~ publisher ~ (pubDate ? ', ' ~ pubDate : '') ~ '.' %}
{% set apa = (authorStr ? authorStr ~ '. ' : '') ~ (pubDate ? '(' ~ pubDate ~ '). ' : '') ~ title ~ '. ' ~ publisher ~ '. ' ~ entryUrl %}

<div class="scv-sidebar-card">
  <div class="scv-sidebar-card-body">
    <span class="scv-sidebar-label">Cite This Article</span>
    <div class="scv-cite-tabs">
      <button class="scv-cite-tab active" onclick="scvCiteTab(this,'cite-chicago')">Chicago</button>
      <button class="scv-cite-tab" onclick="scvCiteTab(this,'cite-mla')">MLA</button>
      <button class="scv-cite-tab" onclick="scvCiteTab(this,'cite-apa')">APA</button>
    </div>
    <div id="cite-chicago" class="scv-cite-panel active">{{ chicago }}</div>
    <div id="cite-mla" class="scv-cite-panel">{{ mla }}</div>
    <div id="cite-apa" class="scv-cite-panel">{{ apa }}</div>
    <button class="scv-cite-copy"
      onclick="var p=document.querySelector('.scv-cite-panel.active');navigator.clipboard.writeText(p.innerText);this.textContent='Copied!';setTimeout(()=>this.textContent='Copy to clipboard',2000)">
      Copy to clipboard
    </button>
  </div>
</div>

<script>
function scvCiteTab(btn, id) {
  document.querySelectorAll('.scv-cite-tab').forEach(t=>t.classList.remove('active'));
  document.querySelectorAll('.scv-cite-panel').forEach(p=>p.classList.remove('active'));
  btn.classList.add('active');
  document.getElementById(id).classList.add('active');
}
</script>
