{#
  _partials/search-form.twig
#}
<form action="{{ url('search') }}" method="get" class="scv-search-form">
  <input type="search" name="q" placeholder="Search SCVHistory…"
         class="scv-search-input"
         value="{{ craft.app.request.getParam('q') }}">
  <button type="submit" class="scv-search-btn" aria-label="Search">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
         stroke="currentColor" stroke-width="2" width="16" height="16">
      <circle cx="11" cy="11" r="8"/>
      <line x1="21" y1="21" x2="16.65" y2="16.65"/>
    </svg>
  </button>
</form>
